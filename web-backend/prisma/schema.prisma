// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ProcessPlan {
  id          Int          @id @default(autoincrement())
  designRule  String       @unique
  beolOptions BeolOption[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model BeolOption {
  id            Int         @id @default(autoincrement())
  optionName    String
  processPlanId Int
  processPlan   ProcessPlan @relation(fields: [processPlanId], references: [id], onDelete: Cascade)
  products      Product[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([processPlanId, optionName])
}

model Product {
  id           Int          @id @default(autoincrement())
  partId       String       @unique
  productName  String
  beolOptionId Int
  beolOption   BeolOption   @relation(fields: [beolOptionId], references: [id], onDelete: Cascade)
  metaInfo     ProductMeta?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model ProductMeta {
  id        Int      @id @default(autoincrement())
  productId Int      @unique
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  chip      String?
  shot      String?
  mto       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
