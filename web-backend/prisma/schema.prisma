generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ProcessPlan {
  id          Int          @id @default(autoincrement())
  designRule  String?      @unique(map: "ix_process_plans_design_rule") @map("design_rule") @db.VarChar
  createdAt   DateTime?    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime?    @default(now()) @updatedAt @map("update_time") @db.Timestamptz(6)
  beolOptions BeolOption[]
  photoKeys   PhotoKey[]

  @@index([id], map: "ix_process_plans_id")
  @@map("process_plans")
}

model BeolOption {
  id            Int          @id @default(autoincrement())
  optionName    String?      @map("option_name") @db.VarChar
  processPlanId Int?         @map("process_plan_id")
  createdAt     DateTime?    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime?    @default(now()) @updatedAt @map("update_time") @db.Timestamptz(6)
  processPlan   ProcessPlan? @relation(fields: [processPlanId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  photoKeys     PhotoKey[]
  products      Product[]

  @@index([id], map: "ix_beol_options_id")
  @@index([optionName], map: "ix_beol_options_option_name")
  @@map("beol_options")
}

model Product {
  id           Int           @id @default(autoincrement())
  partId       String?       @unique(map: "ix_products_partid") @map("partid") @db.VarChar
  productName  String?       @map("product_name") @db.VarChar
  beolOptionId Int?          @map("beol_option_id")
  createdAt    DateTime?     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime?     @default(now()) @updatedAt @map("update_time") @db.Timestamptz(6)
  photoKeys    PhotoKey[]
  metaInfo     ProductMeta?
  beolOption   BeolOption?   @relation(fields: [beolOptionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  requests     RequestItem[]

  @@index([id], map: "ix_products_id")
  @@index([productName], map: "ix_products_product_name")
  @@map("products")
}

model ProductMeta {
  id          Int       @id @default(autoincrement())
  productId   Int?      @unique @map("product_id")
  processId   String?   @map("process_id") @db.VarChar
  mtoDate     DateTime? @map("mto_date")
  customer    String?   @db.VarChar
  application String?   @db.VarChar
  chipSizeX   Float?    @map("chip_size_x")
  chipSizeY   Float?    @map("chip_size_y")
  slSizeX     Float?    @map("sl_size_x")
  slSizeY     Float?    @map("sl_size_y")
  product     Product?  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([id], map: "ix_product_meta_id")
  @@map("product_meta")
}

model RequestItem {
  id          Int       @id @default(autoincrement())
  productId   Int?      @map("product_id")
  title       String    @db.VarChar
  description String?
  edmList     String[]  @map("edm_list") @db.VarChar
  pkdVersions String[]  @map("pkd_versions") @db.VarChar
  requesterId String    @map("requester_id") @db.VarChar
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime? @default(now()) @updatedAt @map("update_time") @db.Timestamptz(6)
  product     Product?  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([id], map: "ix_request_items_id")
  @@map("request_items")
}

model PhotoKey {
  id            Int          @id @default(autoincrement())
  productId     Int?         @map("product_id")
  rfgCategory   String?      @map("rfg_category") @db.VarChar
  photoCategory String?      @map("photo_category") @db.VarChar
  isReference   Boolean?     @default(false) @map("is_reference")
  tableName     String?      @map("table_name") @db.VarChar
  revNo         Int?         @map("rev_no")
  workbookData  Json?        @map("workbook_data") @db.Json
  filename      String?      @db.VarChar
  updater       String?      @db.VarChar
  updateDate    DateTime?    @default(now()) @map("update_date") @db.Timestamptz(6)
  beolOptionId  Int?         @map("beol_option_id")
  processPlanId Int?         @map("process_plan_id")
  log           String?
  rawBinary     Bytes?       @map("raw_binary")
  beolOption    BeolOption?  @relation(fields: [beolOptionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  processPlan   ProcessPlan? @relation(fields: [processPlanId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product       Product?     @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([id], map: "ix_photo_keys_id")
  @@map("photo_keys")
}

model alembic_version {
  version_num String @id(map: "alembic_version_pkc") @db.VarChar(32)
}
