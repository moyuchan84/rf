// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ProcessPlan {
  id          Int          @id @default(autoincrement())
  designRule  String       @unique @map("design_rule")
  beolOptions BeolOption[]

  @@map("process_plans")
}

model BeolOption {
  id            Int         @id @default(autoincrement())
  optionName    String      @map("option_name")
  processPlanId Int         @map("process_plan_id")
  processPlan   ProcessPlan @relation(fields: [processPlanId], references: [id], onDelete: Cascade)
  products      Product[]

  @@unique([processPlanId, optionName])
  @@map("beol_options")
}

model Product {
  id           Int          @id @default(autoincrement())
  partId       String       @unique @map("partid")
  productName  String       @map("product_name")
  beolOptionId Int          @map("beol_option_id")
  beolOption   BeolOption   @relation(fields: [beolOptionId], references: [id], onDelete: Cascade)
  metaInfo     ProductMeta?

  @@map("products")
}

model ProductMeta {
  id        Int     @id @default(autoincrement())
  productId Int     @unique @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  chip      String?
  shot      String?
  mto       String?

  @@map("product_meta")
}
