// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ProcessPlan {
  id          Int          @id @default(autoincrement())
  designRule  String       @unique @map("design_rule")
  beolOptions BeolOption[]
  photoKeys   PhotoKey[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("update_time")

  @@map("process_plans")
}

model BeolOption {
  id            Int         @id @default(autoincrement())
  optionName    String      @map("option_name")
  processPlanId Int         @map("process_plan_id")
  processPlan   ProcessPlan @relation(fields: [processPlanId], references: [id], onDelete: Cascade)
  products      Product[]
  photoKeys     PhotoKey[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("update_time")

  @@unique([processPlanId, optionName])
  @@map("beol_options")
}

model Product {
  id           Int           @id @default(autoincrement())
  partId       String        @unique @map("partid")
  productName  String        @map("product_name")
  beolOptionId Int           @map("beol_option_id")
  beolOption   BeolOption    @relation(fields: [beolOptionId], references: [id], onDelete: Cascade)
  metaInfo     ProductMeta?
  requests     RequestItem[]
  photoKeys    PhotoKey[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("update_time")

  @@map("products")
}

model ProductMeta {
  id        Int     @id @default(autoincrement())
  productId Int     @unique @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  processId   String?   @map("process_id")
  mtoDate     DateTime? @map("mto_date")
  customer    String?
  application String?
  chipSizeX   Float?    @map("chip_size_x")
  chipSizeY   Float?    @map("chip_size_y")
  slSizeX     Float?    @map("sl_size_x")
  slSizeY     Float?    @map("sl_size_y")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("update_time")

  @@map("product_meta")
}

model RequestItem {
  id        Int     @id @default(autoincrement())
  productId Int     @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  requestType String   @map("request_type")
  title       String
  description String   @db.Text
  edmList     String[] @map("edm_list")
  pkdVersions String[] @map("pkd_versions")
  requesterId String   @map("requester_id")

  assignees   RequestAssignee[]
  steps       RequestStep[]
  tables      RequestTableMap[]
  streamInfos StreamInfo[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("update_time")

  @@map("request_items")
}

model PhotoKey {
  id        Int     @id @default(autoincrement())
  productId Int     @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  processPlanId Int?         @map("process_plan_id")
  processPlan   ProcessPlan? @relation(fields: [processPlanId], references: [id], onDelete: Cascade)

  beolOptionId Int?        @map("beol_option_id")
  beolOption   BeolOption? @relation(fields: [beolOptionId], references: [id], onDelete: Cascade)

  rfgCategory   String?  @map("rfg_category") // common, option
  photoCategory String?  @map("photo_category") // info, key
  isReference   Boolean  @default(false) @map("is_reference")
  tableName     String   @map("table_name")
  revNo         Int      @map("rev_no")
  workbookData  Json?    @map("workbook_data")
  filename      String?
  updater       String?
  updateDate    DateTime @default(now()) @map("update_date")

  requestMaps RequestTableMap[]

  @@map("photo_keys")
}

model RequestAssignee {
  id        Int         @id @default(autoincrement())
  requestId Int         @map("request_id")
  request   RequestItem @relation(fields: [requestId], references: [id], onDelete: Cascade)

  category String // RFG_TASK, KEY_TABLE_TASK, etc.
  userId   String @map("user_id")
  userName String @map("user_name")

  @@map("request_assignees")
}

model RequestStep {
  id        Int         @id @default(autoincrement())
  requestId Int         @map("request_id")
  request   RequestItem @relation(fields: [requestId], references: [id], onDelete: Cascade)

  stepOrder   Int       @map("step_order")
  stepName    String    @map("step_name") // ReferenceTable, KeyTableSetup, Submission, GDS
  status      String    @default("TODO") // TODO, IN_PROGRESS, DONE
  workContent String?   @map("work_content") @db.Text
  workerId    String?   @map("worker_id")
  completedAt DateTime? @map("completed_at")

  @@map("request_steps")
}

model RequestTableMap {
  id        Int         @id @default(autoincrement())
  requestId Int         @map("request_id")
  request   RequestItem @relation(fields: [requestId], references: [id], onDelete: Cascade)

  productId     Int? @map("product_id")
  processPlanId Int? @map("process_plan_id")
  beolOptionId  Int? @map("beol_option_id")

  photoKeyId Int      @map("photo_key_id")
  photoKey   PhotoKey @relation(fields: [photoKeyId], references: [id], onDelete: Cascade)

  type String // REFERENCE, SETUP

  @@map("request_tables_map")
}

model StreamInfo {
  id        Int         @id @default(autoincrement())
  requestId Int         @map("request_id")
  request   RequestItem @relation(fields: [requestId], references: [id], onDelete: Cascade)

  productId     Int @map("product_id")
  processPlanId Int @map("process_plan_id")
  beolOptionId  Int @map("beol_option_id")

  streamPath   String   @map("stream_path")
  streamInput  String[] @map("stream_input")
  streamOutput String[] @map("stream_output")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("update_time")

  @@map("stream_info")
}
