<p style="font-size: 16px; margin-top: 0;">상신된 의뢰의 상세 정보입니다.</p>

<div style="padding: 24px; background-color: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; margin-bottom: 32px;">
  <h4 style="margin: 0 0 12px 0; color: #334155; font-size: 14px; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1px solid #e2e8f0; padding-bottom: 8px;">상신 메시지 (Submission Message)</h4>
  <div style="font-size: 15px; color: #1e293b; line-height: 1.6; white-space: pre-wrap;">{{content}}</div>
</div>

{{#if selectedTables}}
<div style="margin-top: 24px; padding: 20px; background-color: #f0f9ff; border: 1px solid #bae6fd; border-radius: 8px;">
  <h4 style="margin: 0 0 12px 0; color: #0369a1; font-size: 14px; text-transform: uppercase; letter-spacing: 0.05em;">SETUP TABLES (첨부파일 바로가기)</h4>
  <table style="width: 100%; border-collapse: collapse; font-size: 13px; background-color: white; border-radius: 4px; overflow: hidden; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">
    <thead>
      <tr style="background-color: #f1f5f9;">
        <th style="padding: 10px 12px; border: 1px solid #e2e8f0; text-align: left; color: #475569;">Table Name</th>
        <th style="padding: 10px 12px; border: 1px solid #e2e8f0; text-align: center; color: #475569; width: 80px;">Rev</th>
        <th style="padding: 10px 12px; border: 1px solid #e2e8f0; text-align: center; color: #475569; width: 100px;">Action</th>
      </tr>
    </thead>
    <tbody>
      {{#each selectedTables}}
      <tr>
        <td style="padding: 10px 12px; border: 1px solid #e2e8f0; color: #1e293b;">{{this.tableName}}</td>
        <td style="padding: 10px 12px; border: 1px solid #e2e8f0; text-align: center; color: #64748b;">REV.{{this.revNo}}</td>
        <td style="padding: 10px 12px; border: 1px solid #e2e8f0; text-align: center;">
          <a href="{{../backendUrl}}/download/photo-key/{{this.id}}" style="color: #0284c7; font-weight: 700; text-decoration: none; display: inline-block; padding: 4px 8px; border: 1px solid #0284c7; border-radius: 4px; font-size: 11px;">DOWNLOAD</a>
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</div>
{{/if}}
