generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  extensions = [vector]
}

model User {
  id            Int      @id @default(autoincrement())
  epId          String   @unique @map("epid") @db.VarChar
  userId        String   @unique @map("user_id") @db.VarChar
  fullName      String   @map("full_name") @db.VarChar
  deptName      String   @map("dept_name") @db.VarChar
  email         String   @db.VarChar
  roleId        Int      @map("role_id")
  role          Role     @relation(fields: [roleId], references: [id])
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("update_time") @db.Timestamptz(6)

  requests      RequestItem[]

  @@index([id], map: "ix_users_id")
  @@map("users")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar // ADMIN, RFG, INNO, USER
  description String?  @db.VarChar
  users       User[]

  @@index([id], map: "ix_roles_id")
  @@map("roles")
}

model ProcessPlan {
  id          Int          @id @default(autoincrement())
  designRule  String?      @unique @map("design_rule") @db.VarChar
  createdAt   DateTime?    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime?    @default(now()) @updatedAt @map("update_time") @db.Timestamptz(6)
  
  beolOptions BeolOption[]
  photoKeys   PhotoKey[]
  keyDesignMaps KeyDesignProcessPlanMap[]
  streamInfos StreamInfo[]

  @@index([id], map: "ix_process_plans_id")
  @@map("process_plans")
}

model BeolOption {
  id            Int          @id @default(autoincrement())
  optionName    String?      @map("option_name") @db.VarChar
  processPlanId Int?         @map("process_plan_id")
  createdAt     DateTime?    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime?    @default(now()) @updatedAt @map("update_time") @db.Timestamptz(6)
  
  processPlan   ProcessPlan? @relation(fields: [processPlanId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  photoKeys     PhotoKey[]
  products      Product[]
  streamInfos   StreamInfo[]

  @@index([id], map: "ix_beol_options_id")
  @@index([optionName], map: "ix_beol_options_option_name")
  @@map("beol_options")
}

model Product {
  id           Int           @id @default(autoincrement())
  partId       String?       @unique @map("partid") @db.VarChar
  productName  String?       @map("product_name") @db.VarChar
  beolOptionId Int?          @map("beol_option_id")
  createdAt    DateTime?     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime?     @default(now()) @updatedAt @map("update_time") @db.Timestamptz(6)
  
  photoKeys    PhotoKey[]
  metaInfo     ProductMeta?
  beolOption   BeolOption?   @relation(fields: [beolOptionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  requests     RequestItem[]
  streamInfos  StreamInfo[]

  @@index([id], map: "ix_products_id")
  @@index([productName], map: "ix_products_product_name")
  @@map("products")
}

model ProductMeta {
  id          Int       @id @default(autoincrement())
  productId   Int?      @unique @map("product_id")
  processId   String?   @map("process_id") @db.VarChar
  customer    String?   @db.VarChar
  application String?   @db.VarChar
  chipSizeX   Float?    @map("chip_size_x")
  chipSizeY   Float?    @map("chip_size_y")
  slSizeX     Float?    @map("sl_size_x")
  slSizeY     Float?    @map("sl_size_y")
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime? @default(now()) @updatedAt @map("update_time") @db.Timestamptz(6)
  
  product     Product?  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([id], map: "ix_product_meta_id")
  @@map("product_meta")
}

model RequestItem {
  id          Int       @id @default(autoincrement())
  productId   Int?      @map("product_id")
  requestType String    @map("request_type") @db.VarChar
  title       String    @db.VarChar
  description String?
  mtoDate     DateTime? @map("mto_date") @db.Timestamptz(6)
  layoutRequestDescription String? @map("layout_request_description") @db.Text
  edmList     String[]  @map("edm_list") @db.VarChar
  pkdVersions String[]  @map("pkd_versions") @db.VarChar
  requesterId String    @map("requester_id") @db.VarChar
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime? @default(now()) @updatedAt @map("update_time") @db.Timestamptz(6)
  
  product     Product?  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  requester   User      @relation(fields: [requesterId], references: [userId])
  assignees   RequestAssignee[]
  steps       RequestStep[]
  streamInfo  StreamInfo[]
  gdsPathInfo GdsPathInfo[]
  tableMaps   RequestTableMap[]
  watcher     RequestWatcher?
  approvalDoc ApprovalDocument?

  @@index([id], map: "ix_request_items_id")
  @@map("request_items")
}

model UserApprovalPath {
  id          Int      @id @default(autoincrement())
  userId      String   @map("user_id") // Employee.userId (EP ID)
  pathName    String   @map("path_name") @db.VarChar
  pathItems   Json     // ApprovalPathDto[] 형태의 배열 저장
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("update_time") @db.Timestamptz(6)

  @@index([userId])
  @@map("user_approval_paths")
}

model ApprovalDocument {
  id          Int      @id @default(autoincrement())
  requestId   Int      @unique @map("request_id")
  apInfId     String   @unique @map("ap_inf_id") @db.VarChar
  docNo       String?  @map("doc_no") @db.VarChar
  status      String   @db.VarChar // DRAFT, SUBMITTED, APPROVED, REJECTED
  payload     Json     // 스냅샷
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("update_time") @db.Timestamptz(6)

  request     RequestItem @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("approval_documents")
}

model UserMailGroup {
  id          Int      @id @default(autoincrement())
  userId      String   @map("user_id") // EP User ID
  groupName   String   @map("group_name") @db.VarChar
  members     Json     // [{ epId, fullName, email, userId }]
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("user_mail_groups")
}

model SystemDefaultMailer {
  id          Int      @id @default(autoincrement())
  category    String   @unique @db.VarChar
  recipients  Json     // [{ epId, fullName, email, userId }]
  
  @@map("system_default_mailers")
}

model RequestWatcher {
  id          Int      @id @default(autoincrement())
  requestId   Int      @unique @map("request_id")
  watchers    Json     // [{ epId, fullName, email, userId, type: 'REQUESTER' | 'ASSIGNEE' | 'WORKER' | 'SUBSCRIBER' }]
  updatedAt   DateTime @updatedAt @map("update_time") @db.Timestamptz(6)

  request     RequestItem @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("request_watchers")
}

model RequestAssignee {
  id        Int    @id @default(autoincrement())
  requestId Int    @map("request_id")
  category  String @db.VarChar
  userId    String @map("user_id") @db.VarChar
  userName  String @map("user_name") @db.VarChar
  user      Json?

  request   RequestItem @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([id], map: "ix_request_assignees_id")
  @@map("request_assignees")
}

model RequestStep {
  id          Int       @id @default(autoincrement())
  requestId   Int       @map("request_id")
  stepOrder   Int       @map("step_order")
  stepName    String    @map("step_name") @db.VarChar
  status      String    @db.VarChar
  workContent String?   @map("work_content") @db.Text
  workerId    String?   @map("worker_id") @db.VarChar
  completedAt DateTime? @map("completed_at") @db.Timestamptz(6)

  request     RequestItem @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([id], map: "ix_request_steps_id")
  @@map("request_steps")
}

model PhotoKey {
  id            Int          @id @default(autoincrement())
  productId     Int?         @map("product_id")
  processPlanId Int?         @map("process_plan_id")
  beolOptionId  Int?         @map("beol_option_id")
  
  rfgCategory   String?      @map("rfg_category") @db.VarChar
  photoCategory String?      @map("photo_category") @db.VarChar
  isReference   Boolean?     @default(false) @map("is_reference")
  tableName     String?      @map("table_name") @db.VarChar
  revNo         Int?         @map("rev_no")
  workbookData  Json?        @map("workbook_data") @db.Json
  rawBinary     Bytes?       @map("raw_binary")
  filename      String?      @db.VarChar
  updater       String?      @db.VarChar
  log           String?      @db.Text
  updateDate    DateTime?    @default(now()) @updatedAt @map("update_date") @db.Timestamptz(6)
  
  beolOption    BeolOption?  @relation(fields: [beolOptionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  processPlan   ProcessPlan? @relation(fields: [processPlanId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product       Product?     @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tableMaps     RequestTableMap[]
  embedding     PhotoKeyEmbedding?

  @@index([id], map: "ix_photo_keys_id")
  @@map("photo_keys")
}

model PhotoKeyEmbedding {
  id          Int                      @id @default(autoincrement())
  photoKeyId  Int                      @unique @map("photo_key_id")
  embedding   Unsupported("vector(1536)")? 
  content     String                   @db.Text
  createdAt   DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)

  photoKey    PhotoKey @relation(fields: [photoKeyId], references: [id], onDelete: Cascade)

  @@map("photo_key_embeddings")
}

model KeyDesign {
  id          Int           @id @default(autoincrement())
  name        String        @db.VarChar
  keyType     String        @map("key_type") @db.VarChar
  sizeX       Float         @map("size_x")
  sizeY       Float         @map("size_y")
  isVertical  Boolean       @map("is_vertical")
  isHorizontal Boolean      @map("is_horizontal")
  rotation    Float
  description String?       @db.Text
  gdsPath     String?       @map("gds_path") @db.VarChar
  edmList     String[]      @map("edm_list") @db.VarChar
  xAxis       Json          @map("x_axis") @db.Json
  yAxis       Json          @map("y_axis") @db.Json
  images      String[]      @db.VarChar
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime      @default(now()) @updatedAt @map("update_time") @db.Timestamptz(6)
  
  processPlanMaps KeyDesignProcessPlanMap[]

  @@index([id], map: "ix_key_designs_id")
  @@map("key_designs")
}

model KeyDesignProcessPlanMap {
  id            Int         @id @default(autoincrement())
  keyDesignId   Int         @map("key_design_id")
  processPlanId Int         @map("process_plan_id")
  
  keyDesign     KeyDesign   @relation(fields: [keyDesignId], references: [id], onDelete: Cascade)
  processPlan   ProcessPlan @relation(fields: [processPlanId], references: [id], onDelete: Cascade)

  @@index([id], map: "ix_key_design_process_plan_maps_id")
  @@map("key_design_process_plan_maps")
}

model ReticleLayout {
  id            Int       @id @default(autoincrement())
  title         String    @db.VarChar
  productId     Int       @map("product_id")
  beolOptionId  Int?      @map("beol_option_id")
  processPlanId Int?      @map("process_plan_id")
  shotInfo      Json?     @map("shot_info") @db.Json
  imageUrl      String?   @map("image_url") @db.VarChar
  boundary      Json?     @db.Json
  chips         Json?     @db.Json
  scribelanes   Json?     @db.Json
  placements    Json?     @db.Json
  config        Json?     @db.Json
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @default(now()) @updatedAt @map("update_time") @db.Timestamptz(6)

  @@index([id], map: "ix_reticle_layouts_id")
  @@map("reticle_layouts")
}

model StreamInfo {
  id                    Int       @id @default(autoincrement())
  requestId             Int       @map("request_id")
  productId             Int       @map("product_id")
  processPlanId         Int       @map("process_plan_id")
  beolOptionId          Int       @map("beol_option_id")
  streamPath            String    @map("stream_path") @db.VarChar
  streamInputOutputFile String?   @map("stream_input_output_file") @db.Text
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @default(now()) @updatedAt @map("update_time") @db.Timestamptz(6)

  request       RequestItem @relation(fields: [requestId], references: [id], onDelete: Cascade)
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  processPlan   ProcessPlan @relation(fields: [processPlanId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  beolOption    BeolOption  @relation(fields: [beolOptionId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([id], map: "ix_stream_info_id")
  @@map("stream_info")
}

model GdsPathInfo {
  id            Int       @id @default(autoincrement())
  requestId     Int       @map("request_id")
  productId     Int       @map("product_id")
  processPlanId Int       @map("process_plan_id")
  beolOptionId  Int       @map("beol_option_id")
  gdsPathList   String[]  @map("gds_path_list") @db.VarChar
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @default(now()) @updatedAt @map("update_time") @db.Timestamptz(6)

  request       RequestItem @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([id], map: "ix_gds_path_info_id")
  @@map("gds_path_info")
}

model RequestTableMap {
  id            Int       @id @default(autoincrement())
  requestId     Int       @map("request_id")
  productId     Int?      @map("product_id")
  processPlanId Int?      @map("process_plan_id")
  beolOptionId  Int?      @map("beol_option_id")
  photoKeyId    Int       @map("photo_key_id")
  type          String    @db.VarChar // REFERENCE, SETUP

  request       RequestItem @relation(fields: [requestId], references: [id], onDelete: Cascade)
  photoKey      PhotoKey    @relation(fields: [photoKeyId], references: [id], onDelete: Cascade)

  @@index([id], map: "ix_request_table_maps_id")
  @@map("request_table_maps")
}
