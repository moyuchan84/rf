# .env.prod (사내 설정)
AI_MODE=prod
EMBEDDING_TYPE=openai # 또는 internal
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
OPENAI_API_KEY=your-corp-key
# OPENAI_BASE_URL=http://your-internal-gateway/v1

# DB & Redis
DB_HOST=10.xxx.xxx.xxx
DB_PORT=5432
DB_NAME=photokey_db
REDIS_URL=redis://your-redis-server:6379
