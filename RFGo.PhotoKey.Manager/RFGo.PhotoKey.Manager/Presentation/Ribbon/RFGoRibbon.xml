<?xml version="1.0" encoding="UTF-8"?>
<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui" onLoad="Ribbon_Load">
  <ribbon>
    <tabs>
      <tab id="tabPhotoKey" label="PhotoKey">
        <group id="groupManager" label="Data Loader">
          <button id="btnOpenTaskPane" label="Folder Upload" 
                  size="large" onAction="OnOpenTaskPane" 
                  imageMso="FileOpen" />
          <button id="btnActiveWorkbookUpload" label="Active Upload" 
                  size="large" onAction="OnActiveWorkbookUpload" 
                  imageMso="FileSaveAs" />
        </group>
        <group id="groupInquiry" label="Data Inquiry">
          <button id="btnOpenInquiryTaskPane" 
                  label="DB Inquiry" 
                  size="large" 
                  onAction="OnOpenInquiryTaskPane" 
                  imageMso="GetExternalDataFromAccess" />
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
