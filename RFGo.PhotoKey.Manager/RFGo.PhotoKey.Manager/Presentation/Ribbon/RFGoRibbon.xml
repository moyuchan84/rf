<?xml version="1.0" encoding="UTF-8"?>
<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui" onLoad="Ribbon_Load">
  <ribbon>
    <tabs>
      <tab id="tabPhotoKey" label="RFGO">

		<group id="groupMaster" label="기준정보관리">
			<button id="btnManageMasterData"
					label="제품정보"
					size="large"
					onAction="OnManageMasterData"
					imageMso="TableDesign" />
		</group>
        <group id="groupManager" label="데이터저장">
          <button id="btnOpenTaskPane" label="폴더저장" 
                  size="large" onAction="OnOpenTaskPane" 
                  imageMso="FileOpen" />
          <button id="btnActiveWorkbookUpload" label="엑셀저장" 
                  size="large" onAction="OnActiveWorkbookUpload" 
                  imageMso="FileSaveAs" />
        </group>
        <group id="groupInquiry" label="데이터관리">
          <button id="btnOpenInquiryTaskPane" 
                  label="조회수정" 
                  size="large" 
                  onAction="OnOpenInquiryTaskPane" 
                  imageMso="GetExternalDataFromAccess" />
        </group>

      </tab>
    </tabs>
  </ribbon>
</customUI>
