{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "rfgo-web-react: dev",
      "type": "npm",
      "script": "dev",
      "path": "rfgo-web-react",
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^.*$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": ".*Local:.*http://localhost:.*"
        }
      }
    },
    {
      "label": "rfgo-embedding-worker: run",
      "type": "shell",
      "command": "${workspaceFolder}/rfgo-embedding-worker/.venv/Scripts/python.exe -m app.main",
      "options": {
        "cwd": "${workspaceFolder}/rfgo-embedding-worker"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "rfgo-rag-backend: run",
      "type": "shell",
      "command": "${workspaceFolder}/rfgo-rag-backend/.venv/Scripts/python.exe -m app.main",
      "options": {
        "cwd": "${workspaceFolder}/rfgo-rag-backend"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    }
  ]
}
