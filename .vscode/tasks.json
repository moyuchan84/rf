{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "web-frontend: dev",
      "type": "npm",
      "script": "dev",
      "path": "web-frontend",
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^.*$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": ".*Local:.*http://localhost:.*"
        }
      }
    }
  ]
}
