{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Python Backend (FastAPI)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--reload",
        "--port",
        "8080"
      ],
      "cwd": "${workspaceFolder}/rfgo-vsto-fastapi",
      "jinja": true,
      "justMyCode": true,
      "python": "${workspaceFolder}/rfgo-vsto-fastapi/.venv/Scripts/python.exe"
    },
     {
      "name": "Debug Python Backend (FastAPI)(WSL)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--reload",
        "--port",
        "8080"
      ],
      "cwd": "${workspaceFolder}/rfgo-vsto-fastapi",
      "jinja": true,
      "justMyCode": true,
      "python": "${workspaceFolder}/rfgo-vsto-fastapi/.venv/bin/python"
    },
    {
      "name": "Debug Web Backend (NestJS)",
      "type": "pwa-node",
      "request": "launch",
      "cwd": "${workspaceFolder}/rfgo-web-nestjs",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start:debug"],
      "sourceMaps": true,
      "restart": true,
      "protocol": "inspector",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "Launch Web Frontend (Vite/Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/rfgo-web-react",
      "preLaunchTask": "rfgo-web-react: dev",
      "sourceMapPathOverrides": {
        "webpack:///src/*": "${webRoot}/src/*",
        "vite:///src/*": "${webRoot}/src/*"
      }
    },
    {
      "name": "Debug Embedding Worker",
      "type": "debugpy",
      "request": "launch",
      "module": "app.main",
      "cwd": "${workspaceFolder}/rfgo-embedding-worker",
      "justMyCode": true,
      "python": "${workspaceFolder}/rfgo-embedding-worker/.venv/Scripts/python.exe",
      "envFile": "${workspaceFolder}/rfgo-embedding-worker/.env"
    },
    {
      "name": "Debug RAG Backend (MCP)",
      "type": "debugpy",
      "request": "launch",
      "module": "app.main",
      "cwd": "${workspaceFolder}/rfgo-rag-backend",
      "justMyCode": true,
      "python": "${workspaceFolder}/rfgo-rag-backend/.venv/Scripts/python.exe",
      "envFile": "${workspaceFolder}/rfgo-rag-backend/.env"
    }
  ],
  "compounds": [
    {
      "name": "Debug Full Stack (RAG)",
      "configurations": [
        "Debug Python Backend (FastAPI)",
        "Debug Web Backend (NestJS)",
        "Launch Web Frontend (Vite/Chrome)",
        "Debug Embedding Worker",
        "Debug RAG Backend (MCP)"
      ],
      "stopAll": true
    }
  ]
}
