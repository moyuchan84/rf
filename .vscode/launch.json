{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Python Backend (FastAPI)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--reload",
        "--port",
        "8080"
      ],
      "cwd": "${workspaceFolder}/backend",
      "jinja": true,
      "justMyCode": true,
      "python": "${workspaceFolder}/backend/.venv/Scripts/python.exe"
    },
    {
      "name": "Debug Web Backend (NestJS)",
      "type": "pwa-node",
      "request": "launch",
      "cwd": "${workspaceFolder}/web-backend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start:debug"],
      "sourceMaps": true,
      "restart": true,
      "protocol": "inspector",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "Launch Web Frontend (Vite/Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/web-frontend",
      "preLaunchTask": "web-frontend: dev",
      "sourceMapPathOverrides": {
        "webpack:///src/*": "${webRoot}/src/*",
        "vite:///src/*": "${webRoot}/src/*"
      }
    }
  ],
  "compounds": [
    {
      "name": "Debug Full Stack",
      "configurations": [
        "Debug Python Backend (FastAPI)",
        "Debug Web Backend (NestJS)",
        "Launch Web Frontend (Vite/Chrome)"
      ],
      "stopAll": true
    }
  ]
}
